# Required
ADMIN_TOKEN=
MASTER_KEY=

# Server
LISTEN_ADDR=0.0.0.0:8080
STATIC_DIR=./static
DB_DSN=sqlite://./data/little_gate.sqlite
DB_MAX_CONNECTIONS=2
RUST_LOG=info

# Request and telemetry
INJECT_INCLUDE_USAGE=true
API_KEY_CACHE_TTL_MS=30000
API_KEY_CACHE_MAX_ENTRIES=2048
UPSTREAM_CACHE_TTL_MS=2000
UPSTREAM_CACHE_STALE_GRACE_MS=30000
MAX_REQUEST_BYTES=4194304
USAGE_CAPTURE_BYTES=65536
USAGE_CAPTURE_TAIL_BYTES=16384
LOG_QUEUE_CAPACITY=256
STATS_FLUSH_INTERVAL_MS=5000

# Routing and failover
ENDPOINT_SELECTOR_STRATEGY=weighted
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_OPEN_MS=30000
UPSTREAM_CONNECT_TIMEOUT_MS=2000
UPSTREAM_REQUEST_TIMEOUT_MS=120000

# Retention and archive
REQUEST_LOG_RETENTION_DAYS=30
STATS_DAILY_RETENTION_DAYS=400
RETENTION_CLEANUP_INTERVAL_MS=21600000
RETENTION_DELETE_BATCH=2000
REQUEST_LOG_ARCHIVE_ENABLED=false
REQUEST_LOG_ARCHIVE_DIR=./data/archive/request_logs
REQUEST_LOG_ARCHIVE_COMPRESS=true
